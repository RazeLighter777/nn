# nn2 database connection configuration
# Copy this file to .env and fill in the values. The app loads .env automatically.
#
# Resolution order (highest → lowest priority):
#   1. --database-url CLI flag
#   2. DATABASE_URL env var  (this file / shell env)
#   3. PGHOST + PGPORT + PGUSER + PGPASSWORD + PGDATABASE env vars
#   4. Default: sqlite://database.db

# ── Option A: full connection URL ─────────────────────────────────────────────
# SQLite (default when nothing is set):
# DATABASE_URL=sqlite://database.db

# PostgreSQL:
# DATABASE_URL=postgres://nn2:nn2secret@localhost:5432/nn2

# ── Option B: individual PostgreSQL parameters (standard libpq names) ─────────
# PGHOST=localhost
# PGPORT=5432
# PGUSER=nn2
# PGPASSWORD=nn2secret
# PGDATABASE=nn2
