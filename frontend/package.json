    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.21.0",
    "eslint-plugin-vue": "^9.32.0",
    "prettier": "^3.5.2",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.24.1",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "vite": "^6.2.3",
    "vue-tsc": "^2.2.4"
